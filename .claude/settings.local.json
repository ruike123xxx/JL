{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(python -m pip install -r requirements.txt -q)",
      "Bash(python -m pytest tests/ -q)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/maintain_agent_md.py\"",
            "statusMessage": "检查 AGENT.md 是否需同步"
          }
        ]
      }
    ]
  }
}
