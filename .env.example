# ===== 服务配置 =====
HOST=127.0.0.1
PORT=8000

# ===== 大模型 provider 选择 =====
# 可选: mock / tongyi
# mock: 返回结构合法的假数据, 无需任何 key, 用于和 RPA 联调
# tongyi: 真实通义模型 (需填下方 key, 见 app/llm/tongyi.py)
LLM_PROVIDER=mock

# ===== 真实模型配置 (LLM_PROVIDER=mock 时可留空) =====
LLM_API_KEY=
LLM_MODEL=qwen-plus
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ===== 数据库 =====
DB_PATH=sessions.db
