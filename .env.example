# ===== 服务配置 =====
HOST=127.0.0.1
PORT=8999

# ===== 大模型 provider 选择 =====
# 可选: mock / tongyi / aliyun
# mock: 返回结构合法的假数据, 无需任何 key, 用于和 RPA 联调
# tongyi: OpenAI 兼容接口 provider, 可接通义 / DeepSeek / 豆包等
# aliyun: 阿里云百炼 DashScope OpenAI 兼容接口 provider
LLM_PROVIDER=aliyun

# ===== 真实模型配置 (LLM_PROVIDER=mock 时可留空) =====
LLM_API_KEY=
LLM_MODEL=qwen3-vl-plus
LLM_VISION_MODEL=qwen3-vl-plus
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ===== 数据库 =====
DB_PATH=sessions.db
