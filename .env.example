# ===== 服务配置 =====
HOST=127.0.0.1
PORT=8000

# ===== 大模型 provider 选择 =====
# 生产: aliyun (阿里云百炼 / DeepSeek 等 OpenAI 兼容接口，改 BASE_URL 和 MODEL 即可)
# 测试: mock (pytest 专用，无需 API key)
LLM_PROVIDER=aliyun

# ===== 模型配置 =====
LLM_API_KEY=your_api_key_here
LLM_MODEL=qwen3-vl-plus
LLM_VISION_MODEL=qwen3-vl-plus
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ===== 数据库 =====
DB_PATH=sessions.db
